<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dragCanvas="clr-namespace:Avalonia.DragCanvas;assembly=Avalonia.DragCanvas"
             xmlns:nodes="clr-namespace:RegexMaker.Controls;assembly=RegexMaker"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RegexMaker.Views.MainView">

    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="120,*,150">
        <Rectangle Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Height="30" Fill="Yellow" />
        <Rectangle Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Height="30" Fill="Purple" />

        <!-- 
        The StackPanel on the left is intended to serve as a toolbox for users to 
        drag and drop different node types onto the DragCanvas. It is set up at
        runtime in RegexMaker.Views.MainView().
        -->
        <StackPanel Grid.Row="1" Grid.Column="0" Name="SpToolBox"/>

        <!-- 
        The Carousel control is used to display the parameters for the currently selected node type.
        Each item in the Carousel corresponds to a different node type, and the content of each item 
        is a set of controls that allow the user to edit the parameters for that node type. The 
        SelectedIndex property of the Carousel is bound to a property in the ViewModel that tracks 
        the currently selected node type, so when the user selects a different node type, 
        the Carousel will automatically update to show the appropriate parameters. 
        -->
        <Carousel Grid.Row="1" Grid.Column="2" SelectedIndex="0" Name="CarParameters" FontSize="12">            
            <!-- StringSearch - Index 0 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Literal" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Value:"/>
                    <TextBox x:Name="TxtStringSearchValue" 
                             Text="{ReflectionBinding SearchString}" 
                             Watermark="Enter search string"/>
                </StackPanel>
            </Border>
            
            <!-- Concatenate - Index 1 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Concatenate" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="No specific parameters" FontStyle="Italic" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Repeat - Index 2 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Repeat" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Minimum:"/>
                    <NumericUpDown x:Name="NumRepeatLeast" 
                                   FormatString="N0" ParsingNumberStyle="Integer"
                                   Value="{ReflectionBinding Least}" 
                                   Minimum="0"/>
                    <TextBlock Text="Maximum:"/>
                    <NumericUpDown x:Name="NumRepeatMost" 
                                   FormatString="N0" ParsingNumberStyle="Integer"
                                   Value="{ReflectionBinding Most}" 
                                   Minimum="-1"/>
                    <CheckBox x:Name="ChkRepeatIsLazy" 
                              IsChecked="{ReflectionBinding IsLazy}" 
                              Content="Lazy"/>
                </StackPanel>
            </Border>
            
            <!-- PatternStart - Index 3 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Pattern Start" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="No specific parameters" FontStyle="Italic" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- PatternEnd - Index 4 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Pattern End" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="No specific parameters" FontStyle="Italic" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- AnyCharFrom - Index 5 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Any Char From" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="No specific parameters" FontStyle="Italic" HorizontalAlignment="Center"/>
                    <TextBlock Text="(Uses parameter nodes)" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- Range - Index 6 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Range" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Start Character:"/>
                    <TextBox x:Name="TxtRangeCharStart" 
                             Text="{ReflectionBinding CharStart}"/>
                    <TextBlock Text="End Character:"/>
                    <TextBox x:Name="TxtRangeCharEnd" 
                             Text="{ReflectionBinding CharEnd}"/>
                </StackPanel>
            </Border>
        </Carousel>

        
        <dragCanvas:DragCanvas Grid.Row="1" ZIndex="-1" Grid.Column="1" Background="LightBlue" 
                               Name="DragCanvasMain" NodeSelected="OnNodeSelected" ConnectionCreated="OnConnectionCreated">
            <nodes:RgxNodeControl NodeName="Concatenate"
                                  Canvas.Left="150" Canvas.Top="50"/>
            <nodes:RgxNodeControl NodeName="Literal"
                                  Canvas.Left="20" Canvas.Top="20"/>
            <nodes:RgxNodeControl NodeName="Literal"
                                  Canvas.Left="20" Canvas.Top="80"/>
            <nodes:RgxNodeControl NodeName="Repeat"
                                  Canvas.Left="200" Canvas.Top="120"/>

<!--            
            <dragCanvas:DragCanvasNode PortCtLeft="2" PortCtRight="3"
                                  Background="LightGray"
                                  Padding="10"
                                  CornerRadius="5"
                                  Canvas.Left="200" Canvas.Top="200">
                <TextBlock Text="String Search Node"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </dragCanvas:DragCanvasNode>
-->
        </dragCanvas:DragCanvas>
    </Grid>
</UserControl>
