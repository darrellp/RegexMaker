<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dragCanvas="clr-namespace:Avalonia.Controls;assembly=Avalonia.DragCanvas"
             xmlns:vm="using:RegexMaker.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RegexMaker.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="120,*,100">
        <Rectangle Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Height="30" Fill="Yellow" />
        <StackPanel Grid.Row="1" Grid.Column="0" Name="SpToolBox">
        </StackPanel>
        <Rectangle Grid.Row="1" Grid.Column="2" Fill="Green" />
        <Rectangle Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Height="30" Fill="Purple" />
        <dragCanvas:DragCanvas Grid.Row="1" ZIndex="-1" Grid.Column="1" Background="LightBlue">
            <dragCanvas:DragCanvasNode PortCtLeft="2" PortCtRight="5"
                                  Background="LightGray"
                                  Padding="10"
                                  CornerRadius="5"
                                  Canvas.Left="200" Canvas.Top="200">
            <TextBlock Text="String Search Node"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
            </dragCanvas:DragCanvasNode>

        </dragCanvas:DragCanvas>
    </Grid>
</UserControl>
