<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:dragCanvas="clr-namespace:Avalonia.DragCanvas;assembly=Avalonia.DragCanvas"
             xmlns:nodes="clr-namespace:RegexMaker.Controls;assembly=RegexMaker"
             xmlns:vm="using:RegexMaker.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RegexMaker.Views.MainView"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="Auto,*,120,Auto" ColumnDefinitions="120,*,150">
        <!-- Top panel with buttons -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Background="Yellow" Height="30">
            <Button Content="Save" Margin="5,2" Padding="10,2" Command="{Binding SaveCommand}" />
            <Button Content="Load" Margin="5,2" Padding="10,2" Command="{Binding LoadCommand}" />
            <Button Content="Clear" Margin="5,2" Padding="10,2" Command="{Binding ClearCommand}" />
            <Button Content="Copy Regex" Margin="5,2" Padding="10,2" Command="{Binding CopyRegexCommand}" />
        </StackPanel>

        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" BorderBrush="Black" BorderThickness="1" Margin="5">
            <AvaloniaEdit:TextEditor Name="SampleTextEditor" Text="Replace with Sample Text"
                           FontFamily="Cascadia Code,Consolas,Menlo,Monospace"/>
        </Border>

        <!--
        This Border at the bottom is intended to display the generated regex pattern.
        -->
        <Border Height="20" Background="LightGray" Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="3" >
            <TextBlock Name="TxtRegex" VerticalAlignment="Center" Text="{Binding RegexPattern}"/>
        </Border>

        <!-- 
        The StackPanel on the left is intended to serve as a toolbox for users to 
        drag and drop different node types onto the DragCanvas. It is set up at
        runtime in RegexMaker.Views.MainView().
        -->
        <StackPanel Grid.Row="1" Grid.Column="0" Name="SpToolBox"/>

        <!--
        The DragCanvas - the main canvas where nodes are placed and connected.
        This is positioned in the center column between the toolbox and parameters panel.
        -->
        <dragCanvas:DragCanvas Grid.Row="1" Grid.Column="1" 
                              Name="DragCanvasMain"
                              Background="LightBlue"
                              NodeSelected="OnNodeSelected"
                              ConnectionCreated="OnConnectionCreated"
                              ConnectionDeleted="OnConnectionDeleted"
                              NodeDeleted="OnNodeDeleted"/>

        <!-- 
        The Carousel control is used to display the parameters for the currently selected node type.
        Each item in the Carousel corresponds to a different node type, and the content of each item 
        is a set of controls that allow the user to edit the parameters for that node type. The 
        SelectedIndex property of the Carousel is bound to a property in the ViewModel that tracks 
        the currently selected node type, so when the user selects a different node type, 
        the Carousel will automatically update to show the appropriate parameters.
        
        All carousel items now bind to the shared CurrentNodeViewModel property using ReflectionBinding
        for dynamic type support.
        -->
        <Carousel Grid.Row="1" Grid.Column="2" 
                  SelectedIndex="{Binding SelectedCarouselIndex}" 
                  Name="CarParameters" 
                  FontSize="12">            
            <!-- StringSearch - Index 0 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Literal" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Value:"/>
                    <TextBox Text="{ReflectionBinding SearchString}" 
                             Watermark="Enter search string"/>
                    <CheckBox IsChecked="{ReflectionBinding AutoEscape}" 
                              Content="Auto Escape"/>
                </StackPanel>
            </Border>
            
            <!-- Concatenate - Index 1 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Concatenate" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Port Count:"/>
                    <NumericUpDown FormatString="N0" ParsingNumberStyle="Integer"
                                   Value="{ReflectionBinding PortCount}" 
                                   Minimum="2"
                                   Maximum="10"/>
                </StackPanel>
            </Border>
            
            <!-- Repeat - Index 2 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Repeat" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Minimum:"/>
                    <NumericUpDown FormatString="N0" ParsingNumberStyle="Integer"
                                   Value="{ReflectionBinding Least}" 
                                   Minimum="0"
                                   Maximum="{ReflectionBinding MaximumForLeast}"/>
                    <TextBlock Text="Maximum:"/>
                    <NumericUpDown FormatString="N0" ParsingNumberStyle="Integer"
                                   Value="{ReflectionBinding Most}" 
                                   Minimum="{ReflectionBinding Least}"
                                   Maximum="999999"
                                   IsEnabled="{ReflectionBinding IsMostEnabled}"/>

                    <CheckBox IsChecked="{ReflectionBinding IsInfinity}" 
                              Content="Set Maximum to Infinity"/>

                    <CheckBox IsChecked="{ReflectionBinding IsLazy}" 
                              Content="Lazy"/>
                </StackPanel>
            </Border>
            
            <!-- PatternStart - Index 3 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Pattern Start" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="No specific parameters" FontStyle="Italic" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- PatternEnd - Index 4 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5">
                    <TextBlock Text="Pattern End" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="No specific parameters" FontStyle="Italic" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- AnyCharFrom - Index 5 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Any Char From" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Default Characters:"/>
                    <TextBox Text="{ReflectionBinding Chars}" 
                             Watermark="A-Za-z0-9"/>
                    <CheckBox Content="Not In Char Set" IsChecked="{ReflectionBinding NotIn}" />
                    <TextBlock Text="(Also uses parameter nodes)" 
                               FontStyle="Italic" 
                               HorizontalAlignment="Center"
                               FontSize="10"/>
                </StackPanel>
            </Border>

            <!-- AnyOf - Index 6 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Any Of" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Port Count:"/>
                    <NumericUpDown FormatString="N0" ParsingNumberStyle="Integer"
                                   Value="{ReflectionBinding PortCount}" 
                                   Minimum="2"
                                   Maximum="10"/>
                </StackPanel>
            </Border>
            
            <!-- Range - Index 7 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Range" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Start Character:"/>
                    <TextBox Text="{ReflectionBinding CharStart}"/>
                    <TextBlock Text="End Character:"/>
                    <TextBox Text="{ReflectionBinding CharEnd}"/>
                </StackPanel>
            </Border>

            <!-- CharClassNode - Index 8 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Char Class" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Class Type:"/>
                    <ComboBox ItemsSource="{ReflectionBinding CharClassTypes}"
                              SelectedItem="{ReflectionBinding SelectedCharClass, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Named - Index 9 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Named" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Value:"/>
                    <TextBox Text="{ReflectionBinding GroupName}" 
                             Watermark="Enter group name"/>
                </StackPanel>
            </Border>

            <!-- Date - Index 10 -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <StackPanel Spacing="5" DataContext="{Binding CurrentNodeViewModel}">
                    <TextBlock Text="Date" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <CheckBox Content="American" IsChecked="{ReflectionBinding IsAmerican}" />
                </StackPanel>
            </Border>

        </Carousel>
    </Grid>
</UserControl>
